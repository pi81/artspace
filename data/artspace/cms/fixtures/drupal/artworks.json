        "body": {
          "value": "<!-- wp:heading --><h3>Geometric abstraction</h3><!-- /wp:heading -->",
          "processed": "<!-- wp:heading {\"level\":3} -->\n<h3>Geometric abstraction</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Bold geometric forms arranged in dynamic tension across the canvas plane.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:list {\"ordered\":true} -->\n<ol><li>Primary geometric planes</li><li>Intersecting diagonals</li><li>Contrasting color fields</li></ol>\n<!-- /wp:list -->",
