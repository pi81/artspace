      "attributes": {
        "title": "Edward Hopper",
        "path": { "alias": "/artists/edward-hopper" },
        "field_birth_year": 1882,
        "field_death_year": 1967,
        "body": {
          "value": "<!-- wp:paragraph --><p>American realist painter.</p><!-- /wp:paragraph -->",
          "processed": "<!-- wp:paragraph -->\n<p>American realist painter whose spare compositions explore solitude, silence, and the psychology of modern life.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>Hopper's use of light and shadow transforms everyday settings — diners, offices, gas stations — into scenes of quiet drama.</p>\n<!-- /wp:paragraph -->",
          "format": "gutenberg"
        }
      }
    },
