        "field_birth_year": 1853,
        "field_death_year": 1890,
        "body": {
          "value": "<!-- wp:paragraph --><p>Dutch post-impressionist painter.</p><!-- /wp:paragraph -->",
          "processed": "<!-- wp:paragraph -->\n<p>Dutch post-impressionist painter whose bold colors and expressive brushwork profoundly influenced modern art.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:heading {\"level\":2} -->\n<h2>Legacy</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Though he sold only one painting during his lifetime, van Gogh's work is now among the most celebrated in Western art.</p>\n<!-- /wp:paragraph -->",
          "format": "gutenberg"
        }
      }
    },
