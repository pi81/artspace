        "path": { "alias": "/artists/claude-monet" },
        "field_birth_year": 1840,
        "field_death_year": 1926,
        "body": {
          "value": "<!-- wp:paragraph --><p>French impressionist painter.</p><!-- /wp:paragraph -->",
          "processed": "<!-- wp:paragraph -->\n<p>French impressionist painter and founder of the movement, best known for his series of water lily paintings.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:heading {\"level\":2} -->\n<h2>Giverny years</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>From his garden studio in Giverny, Monet pursued serial studies of light, atmosphere, and reflection on water.</p>\n<!-- /wp:paragraph -->",
          "format": "gutenberg"
        }
      }
    },
