        "title": "Mary Cassatt",
        "path": { "alias": "/artists/mary-cassatt" },
        "field_birth_year": 1844,
        "field_death_year": 1926,
        "body": {
          "value": "<!-- wp:paragraph --><p>American impressionist painter.</p><!-- /wp:paragraph -->",
          "processed": "<!-- wp:paragraph -->\n<p>American impressionist painter and printmaker, known for intimate depictions of mothers and children.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:heading {\"level\":2} -->\n<h2>Paris circle</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Cassatt exhibited with the Impressionists in Paris and helped shape American collecting through her advocacy of modern French art.</p>\n<!-- /wp:paragraph -->",
          "format": "gutenberg"
        }
      }
