        "title": "Grant Wood",
        "path": { "alias": "/artists/grant-wood" },
        "field_birth_year": 1891,
        "field_death_year": 1942,
        "body": {
          "value": "<!-- wp:paragraph --><p>American Regionalist painter.</p><!-- /wp:paragraph -->",
          "processed": "<!-- wp:paragraph -->\n<p>American painter associated with the Regionalist movement, celebrated for scenes of Midwestern rural life.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:heading {\"level\":2} -->\n<h2>Stone City</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Wood co-founded the Stone City Art Colony in Iowa, mentoring artists who shared his interest in local subject matter.</p>\n<!-- /wp:paragraph -->",
          "format": "gutenberg"
        }
      }
    },
    {
      "type": "node--artist",
